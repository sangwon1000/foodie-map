        <name>Restaurant Poloz Mukuch</name>
        <description>Tony had a meal with some locals: oxtail soup; stewed liver and heart with tomato, onions, and fresh herbs; sheep’s head.</description>
        <styleUrl>#icon-1577-C2185B</styleUrl>
        <Point>
          <coordinates>
            43.8384164,40.7880108,0
          </coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>Meal with locals</name>
        <description>Tony had a meal of khash (stock flavored by roasted-beef bones) with lavash.</description>
        <styleUrl>#icon-1603-9C27B0</styleUrl>
        <Point>
          <coordinates>
