        <name><![CDATA[At Gayane's]]></name>
        <description>Tony had apricot vodka, and trout wrapped and baked in lavash</description>
        <styleUrl>#icon-1577-C2185B</styleUrl>
        <Point>
          <coordinates>
            44.509911,40.186571,0
          </coordinates>
        </Point>
