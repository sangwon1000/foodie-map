        </Point>
      </Placemark>
      <Placemark>
        <name>Bar Guillermina</name>
        <description>Tony and José Andrés had a bowl of beans with sausage and some cider. After they ate, they played a game similar to bowling.</description>
        <styleUrl>#icon-1577-C2185B</styleUrl>
        <Point>
