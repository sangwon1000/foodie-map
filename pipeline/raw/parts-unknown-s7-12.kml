        <name>Dargett Craft Beer</name>
        <description>Tony had beers here with Tech journalist Artur Papayan, developer Harut Martirosyan, and cybersecurity consultant Ruben Muradyan.</description>
        <styleUrl>#icon-1879-FFD600</styleUrl>
        <Point>
          <coordinates>
