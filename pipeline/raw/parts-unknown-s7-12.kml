          </coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>Fleamarket at Mauerpark</name>
        <description>Tony visited this flea market with Anton and his son Wolfgang. They purchased records at one stand.</description>
        <styleUrl>#icon-1684-0288D1</styleUrl>
