      <Placemark>
        <name>El Trasmayo</name>
        <description>Tony met with chef and entrepreneur Pedro Álvarez Cortez at this crab shack. They had crab, coconut arepas, and beer.</description>
        <styleUrl>#icon-1577-C2185B</styleUrl>
        <Point>
