        <name>Alrowwad Cultural and Arts Societyجمعية الرواد للثقافة والفنون‎</name>
        <description>Palestinian children from the Aida Refugee Camp participate in a theater production here</description>
        <styleUrl>#icon-1523-0288D1</styleUrl>
        <Point>
          <coordinates>
            35.197358,31.71962,0
          </coordinates>
        </Point>
