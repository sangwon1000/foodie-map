          </coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>Noma</name>
        <description><![CDATA[Tony visited Chef Rene Redzepi at this restaurant, which is known to many as "the best restaurant in the world." Tony came to Denmark solely to visit this restaurant.]]></description>
        <styleUrl>#icon-1577-C2185B</styleUrl>
