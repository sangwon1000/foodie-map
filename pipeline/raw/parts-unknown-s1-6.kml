          </coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>Choon Hui Cafe</name>
        <description><![CDATA[Tony calls Sarawak laksa "a magical dish," it has chicken, prawn, coconut, chili, and noodles in a complex broth. “Best breakfast ever.”]]></description>
        <styleUrl>#icon-1640-C2185B</styleUrl>
        <Point>
