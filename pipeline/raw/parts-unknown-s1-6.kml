        <name>Kirtland Air Force Base</name>
        <description><![CDATA[Two members of the New Mexico UFO & paranormal forum, Norio and James, met Tony outside here to talk about America's first rocketships.]]></description>
        <styleUrl>#icon-1751-FF5252</styleUrl>
        <Point>
          <coordinates>
            -106.5112712,35.0128396,0
          </coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>Dead Horse Ranch</name>
        <description>Margaritas and beer, and a whole roast pig is cooked underground in a barbecue known as a matanza.</description>
        <styleUrl>#icon-1577-9C27B0</styleUrl>
        <Point>
          <coordinates>
