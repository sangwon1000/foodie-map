        <name>Restaurante Oliver</name>
        <description>Bar #2 for Tony, Zach, and Fuen. They had mussels steamed in butter and olive oil.</description>
        <styleUrl>#icon-1577-C2185B</styleUrl>
        <Point>
          <coordinates>
