        <name>Bellevue Bar</name>
        <description>Bar for chefs to wind down</description>
        <styleUrl>#icon-1577-C2185B</styleUrl>
        <Point>
          <coordinates>
            -73.9934249,40.7569239,0
          </coordinates>
        </Point>
      </Placemark>
