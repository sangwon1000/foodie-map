        <Point>
          <coordinates>
            -70.18534,42.0519967,0
          </coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name><![CDATA[Ciro & Sal's]]></name>
        <description><![CDATA[Tony's first big break: working as a line cook at this Italian/seafood restaurant. Tony's favorite is the veal marsala.]]></description>
        <styleUrl>#icon-1577-C2185B</styleUrl>
        <Point>
          <coordinates>
            -70.1808599,42.0557602,0
          </coordinates>
        </Point>
      </Placemark>
      <Placemark>
        <name>The Culinary Institute of America</name>
        <description>Tony visited his alma mater where he went to culinary school and learned classic French techniques</description>
        <styleUrl>#icon-1726-F9A825</styleUrl>
        <Point>
          <coordinates>
            -73.933346,41.745685,0
          </coordinates>
        </Point>
      </Placemark>
